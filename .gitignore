# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts


# Local-only working directory — never committed
# Use this for personal scratch, drafts you don't want public,
# outreach drafts that name specific people, financial planning, etc.
_internal/

# Personal application drafts and outreach scratch — never commit to public repo.
# These patterns are defensive against the same accidental-commit pattern that
# happened in commit 6672bef ("URGENT: remove personal docs accidentally pushed
# to public repo") and again in commits before v0.6.7.
docs/MORNING-REVIEW.md
docs/TOMORROW-MORNING.md
docs/anthropic-*-application-draft.md
docs/*-application-draft.md
docs/grant-applications-log.md
docs/manifund-*.md
docs/resume-*.md
docs/endorser-outreach.md
docs/arxiv-endorsement-emails.md
docs/reddit-posts-drafts.md
docs/post-split-action-checklist.md
docs/outreach/

# clinician-meeting-memo-template.md is the *template* (kept in repo);
# filled-in audit memos go to docs/clinician-audits/<name>-<date>.md and
# should NOT be committed publicly because they identify clinical reviewers.
docs/clinician-audits/

# Older test artifacts not part of the published v0.6 paper
data/zh-trigger-test-2026-04-29.json
data/zh-trigger-test-v091-2026-04-29.json
scripts/test-zh-trigger.ts
scripts/test-zh-trigger-v091.ts
